APP_ROOT=/app
APP_ENV_FILE=

TELEGRAM_TOKEN=8562311306:AAGVyVPoluAtA7iRSaIwLRt95bEJ-ifFiDc
TELEGRAM_BOT_URL=https://t.me/MaxKonvert_Support_dev_bot

# Model provider: local | kimi
MODEL_PROVIDER=kimi

# --- Local (Ollama) settings ---
HOST_OLLAMA_DATA_PATH=./kb/ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_SECONDS=30.0

# --- Kimi (Moonshot) settings ---
KIMI_API_TOKEN=sk-kimi-qm3dYZbo8X3DPj27yTNEjLvxW48arReSgF3abidREyrjxv28C7w1Rvk9KcBn5FcT
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_TIMEOUT_SECONDS=30.0

# Paths
HOST_KB_DOCS_PATH=./kb/docs
HOST_KB_QUESTIONS_PATH=./kb/questions
HOST_KB_INDEX_PATH=./kb/index

DOCS_PATH=/app/kb/docs
INDEX_PATH=/app/kb/index
QUESTIONS_DIR=/app/kb/questions
LOG_PATH=/app/kb/questions/logs

# HTTP actions config (optional)
ACTIONS_CONFIG_PATH=/app/kb/http_actions.json

# Retrieval / embedding
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
TOP_K=5
SIMILARITY_THRESHOLD=0.12
LOW_CONFIDENCE_MODEL_SCORE=0.18
CONTEXT_TURNS=6
RETRIEVAL_HISTORY_TURNS=2
MAX_CONTEXT_CHARS=1800
MAX_DOC_SNIPPET_CHARS=450
MAX_DOC_FRAGMENTS=3
MAX_ANSWER_CHARS=1600

# Ports
BOT_HEALTH_PORT=8081
API_PORT=8082
DOCS_EDITOR_PORT=8090

# Editor / reindex
DOCS_EDITOR_HOST=0.0.0.0
PYTHON_BIN=python3
REINDEX_SCRIPT=/app/scripts/reindex.py
REINDEX_INTERVAL_SEC=300
DEBOUNCE_SEC=3
REINDEX_LOCK_WAIT_SECONDS=180

# Bot persona
BOT_ROLE=Ты — опытный sales-менеджер MaxKonvert в Telegram. Ты ведёшь диалог как живой человек и мягко доводишь пользователя до следующего шага.
BOT_EXTRA_RULES=Отвечай на языке пользователя. Пиши естественно, без канцелярита. Не используй формулировки вида «нет в документации», «я не знаю». Если данных мало, дай полезный ориентир и задай один уточняющий вопрос. Не выдумывай конкретные цифры и факты.
SALES_DEFAULT_CTA=Уточните GEO, объём трафика в сутки и предпочитаемый формат (MT, WAP, pseudo, premium SMS).
