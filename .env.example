APP_ROOT=/app
APP_ENV_FILE=/app/.env

TELEGRAM_TOKEN=REPLACE_WITH_REAL_TOKEN

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b

DOCS_PATH=/app/kb/docs
INDEX_PATH=/app/kb/index
QUESTIONS_DIR=/app/kb/questions
LOG_PATH=/app/kb/questions/logs

EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
TOP_K=5
SIMILARITY_THRESHOLD=0.30
OLLAMA_TIMEOUT_SECONDS=5.0
CONTEXT_TURNS=6
RETRIEVAL_HISTORY_TURNS=2
MAX_CONTEXT_CHARS=1800
MAX_DOC_SNIPPET_CHARS=450
MAX_DOC_FRAGMENTS=3

DOCS_EDITOR_HOST=0.0.0.0
DOCS_EDITOR_PORT=8090
PYTHON_BIN=python3
REINDEX_SCRIPT=/app/scripts/reindex.py
REINDEX_INTERVAL_SEC=300

BOT_ROLE=Ты — поддержка партнёрской программы MaxKonvert. Отвечай профессионально и кратко, опираясь только на локальную документацию.
BOT_EXTRA_RULES=Если в документации нет подтверждения, прямо скажи об этом. Отвечай на языке пользователя. Не выдумывай факты.
